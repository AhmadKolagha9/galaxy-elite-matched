NODE_ENV=development
PORT=4000
CORS_ORIGIN=https://match.galaxyelite.ae,http://localhost:3000
API_NAME=Galaxy Elite Private Match API

# SQL persistence
MYSQL_DATABASE_URL=mysql://galaxy_test:galaxy_test_password@127.0.0.1:3307/galaxy_elite_test
DATABASE_URL=mysql://galaxy_test:galaxy_test_password@127.0.0.1:3307/galaxy_elite_test

# Supabase Auth / JWT validation
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Native auth / JWT sessions
AUTH_JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
AUTH_JWT_EXPIRES_IN_SECONDS=28800
BCRYPT_SALT_ROUNDS=12

# Optional internal bridge key for trusted server-to-server dashboard calls.
INTERNAL_API_KEY=change-me

# Local-only header auth for development. Disable in production.
ENABLE_DEV_AUTH=true

# Private document storage bucket name.
PRIVATE_DOCUMENT_BUCKET=private-documents

# Firebase Functions deployment options
FIREBASE_FUNCTION_REGION=us-central1
FIREBASE_FUNCTION_MAX_INSTANCES=10

# Firebase Admin / Firestore backend configuration
FIREBASE_PROJECT_ID=galaxy-elite-mathed
FIREBASE_AUTH_DOMAIN=galaxy-elite-mathed.firebaseapp.com
FIREBASE_STORAGE_BUCKET=galaxy-elite-mathed.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=894546549848
FIREBASE_APP_ID=1:894546549848:web:7e681830113099673ebe2d
FIREBASE_MEASUREMENT_ID=G-HD1LLJJRHJ
# For local server-side Firebase Admin only. In Firebase Functions, ADC is usually enough.
FIREBASE_SERVICE_ACCOUNT_JSON=
FIRESTORE_NOTIFICATIONS_COLLECTION=notification_logs

# Notification broker / transactional email
NOTIFICATION_WEBHOOK_SECRET=change-me-webhook-secret
EMAIL_PROVIDER=resend
EMAIL_FROM=Galaxy Elite <notifications@your-domain.com>
RESEND_API_KEY=
SENDGRID_API_KEY=
POSTMARK_SERVER_TOKEN=
ADMIN_NOTIFICATION_EMAILS=admin@your-domain.com
