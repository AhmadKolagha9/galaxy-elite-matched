# Galaxy Elite Corporate Control Platform
# This standalone dashboard is closed by default. /login is the only public UI route.

NEXT_PUBLIC_SITE_URL=https://control.galaxyelite.ae
NEXT_PUBLIC_ADMIN_DASHBOARD_ORIGIN=https://control.galaxyelite.ae
ADMIN_DASHBOARD_ORIGIN=https://control.galaxyelite.ae

# Express API that verifies Firebase ID tokens with Firebase Admin SDK.
BACKEND_API_URL=https://api.galaxyelite.ae
ADMIN_AUTH_VERIFY_PATH=/api/profile/me

# Firebase Client SDK values for staff email/password login.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional Sanity read settings if the dashboard needs editorial previews later.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2026-05-26
SANITY_WRITE_TOKEN=
