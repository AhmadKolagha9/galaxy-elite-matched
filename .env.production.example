# Production/staging environment template.
# Values are intentionally empty. Fill these in the deployment platform secret manager.

# Remote application URLs
PRODUCTION_WEBSITE_URL=
PRODUCTION_BACKEND_API_URL=
PRODUCTION_ADMIN_DASHBOARD_URL=
PRODUCTION_CORS_ORIGIN=

# Backend required values
MYSQL_DATABASE_URL=
DATABASE_URL=
AUTH_JWT_SECRET=
PRIVATE_DOCUMENT_BUCKET=
CORS_ORIGIN=
BACKEND_PORT=

# Website/backend bridge values
BACKEND_API_URL=
NEXT_PUBLIC_BACKEND_API_URL=
NEXT_PUBLIC_SITE_URL=

# Admin dashboard values
ADMIN_DASHBOARD_ORIGIN=
NEXT_PUBLIC_ADMIN_DASHBOARD_ORIGIN=

# Internal server-to-server auth
BACKEND_INTERNAL_API_KEY=
INTERNAL_API_KEY=

# Optional CMS/provider values
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
SANITY_API_VERSION=
SANITY_WRITE_TOKEN=

# Optional notification values
EMAIL_PROVIDER=
EMAIL_FROM=
RESEND_API_KEY=
SENDGRID_API_KEY=
POSTMARK_SERVER_TOKEN=
ADMIN_NOTIFICATION_EMAILS=
FIRESTORE_NOTIFICATIONS_COLLECTION=

# Optional Firebase/Admin provider values
