{
  "name": "galaxy-elite-private-match-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript Express API for Galaxy Elite Private Match.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:migrate": "node scripts/run-migrations.mjs",
    "auth:token": "node scripts/create-admin-token.mjs",
    "auth:staff": "node scripts/upsert-native-staff-user.mjs"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.4",
    "nodemailer": "^6.10.1",
    "resend": "^6.5.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.30",
    "@types/nodemailer": "^6.4.23",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
