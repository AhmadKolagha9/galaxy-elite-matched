# Main public site URL used for metadata, canonical URLs, JSON-LD, sitemap, and social previews.
NEXT_PUBLIC_SITE_URL=https://galaxyelite.ae

# Supabase production authentication. The app works without these using local demo auth.
# For production, create a Supabase project and set these in Vercel.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy key name also supported if your project still uses anon keys:
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Used only for local demo auth signing. Generate a long random string for production-like demos.
AUTH_SECRET=replace-with-a-long-random-secret

# Sanity CMS. The site works without these and falls back to bundled sample content.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2026-05-26
SANITY_WRITE_TOKEN=

# Optional email/ops settings for future integrations.
OPERATIONS_EMAIL=hello@galaxyelite.ae
WHATSAPP_NUMBER=971000000000

# Comma-separated admin emails allowed to access /admin in production
ADMIN_EMAILS=admin@galaxyelite.ae

# Express backend API used by Next route handlers to forward authenticated submissions and taxonomy reads.
BACKEND_API_URL=http://localhost:4000
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:4000

# Firebase client authentication used for browser auth state and ID token forwarding.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=galaxy-elite-mathed.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=galaxy-elite-mathed
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=galaxy-elite-mathed.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=894546549848
NEXT_PUBLIC_FIREBASE_APP_ID=1:894546549848:web:7e681830113099673ebe2d
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-HD1LLJJRHJ
